{
  "name": "morun",
  "private": true,
  "version": "0.0.1",
  "description": "MO:RUN - Running community platform (web + mobile + api)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "web": "turbo run dev --filter=@morun/web",
    "mobile": "turbo run dev --filter=@morun/mobile",
    "api": "turbo run dev --filter=@morun/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  }
}
