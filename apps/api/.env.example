PORT=4000

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Postgres schema. Same project hosts both 'public' (prod) and 'test'
# (test data) schemas — switch by env. See supabase/SETUP.md.
SUPABASE_DB_SCHEMA=public

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,exp://localhost:8081
